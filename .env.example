# Supabase (web + worker — URL is the same project)
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (web — Vercel env vars)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_ID_PRO_MONTHLY=price_...

# App URL (Vercel production URL)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Email alerts (worker — GitHub Actions secrets)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=intel@yourdomain.com

# Optional Slack ops alerts
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C...
